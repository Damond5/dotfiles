#!/bin/bash

# maintenance
sudo pacman -Syu --needed --noconfirm
sudo pacman -S --needed --noconfirm yay
yay -Syu --needed --noconfirm


# BASE
yay -S --needed --noconfirm bash-completion
yay -S --needed --noconfirm vim
yay -S --needed --noconfirm alacritty
yay -S --needed --noconfirm redshift
yay -S --needed --noconfirm timeshift
yay -S --needed --noconfirm chromium
yay -S --needed --noconfirm chromium-widevine
yay -S --needed --noconfirm flatpak
flatpak install -y discord
yay -S --needed --noconfirm mpv
yay -S --needed --noconfirm mlocate


# DEVELOPMENT
yay -S --needed --noconfirm qt
yay -S --needed --noconfirm qtcreator

# youcompleteme
yay -S --needed --noconfirm cmake
yay -S --needed --noconfirm mono
yay -S --needed --noconfirm go
yay -S --needed --noconfirm npm
yay -S --needed --noconfirm jdk8-openjdk
yay -S --needed --noconfirm python2


# TABLET
yay -S --needed --noconfirm onboard
