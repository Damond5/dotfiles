{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "gemma4": {
          "_launch": true,
          "name": "gemma4"
        },
        "gemma4:26b": {
          "_launch": true,
          "name": "gemma4:26b"
        },
        "gemma4:31b": {
          "_launch": true,
          "name": "gemma4:31b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  }
}
